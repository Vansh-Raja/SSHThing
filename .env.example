NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Set one of these Clerk issuer variables.
CLERK_FRONTEND_API_URL=https://your-frontend-api.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://your-frontend-api.clerk.accounts.dev

# `convex dev` writes these automatically for local development.
CONVEX_DEPLOYMENT=dev:your-deployment
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site

# Optional override if you are not using CONVEX_URL directly.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

SSHTHING_BROWSER_BASE_URL=http://localhost:3000

# Required in production for team-host credential encryption.
# Local development falls back to a generated secret in `.local/sshthing-team-secret.key`.
SSHTHING_TEAM_SECRET_KEY=
