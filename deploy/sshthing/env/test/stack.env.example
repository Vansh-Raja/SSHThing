# Docker Compose project / stack identity
COMPOSE_PROJECT_NAME=sshthing-test
INSTANCE_NAME=sshthing-test

# Multi-arch images.
# If you pin digests later, pin the manifest-list digest instead of an amd64-only digest.
POSTGRES_IMAGE=postgres:17
CONVEX_BACKEND_IMAGE=ghcr.io/get-convex/convex-backend:latest
CONVEX_DASHBOARD_IMAGE=ghcr.io/get-convex/convex-dashboard:latest
WEB_IMAGE=sshthing-web:test

# Volume names
POSTGRES_VOLUME_NAME=sshthing_test_postgres_data
CONVEX_DATA_VOLUME_NAME=sshthing_test_convex_data

# Loopback-only published ports
WEB_PORT=3001
CONVEX_API_PORT=3220
CONVEX_SITE_PORT=3221
CONVEX_DASHBOARD_PORT=6792
POSTGRES_PORT=5433

# Postgres persistence for Convex
POSTGRES_USER=sshthing
POSTGRES_PASSWORD=replace-with-generated-postgres-password
POSTGRES_DB=sshthing_test
POSTGRES_URL=postgresql://sshthing:replace-with-generated-postgres-password@postgres:5432
DO_NOT_REQUIRE_SSL=1

# Convex backend runtime
INSTANCE_SECRET=replace-with-generated-instance-secret
CONVEX_CLOUD_ORIGIN=https://api-test.example.com
CONVEX_SITE_ORIGIN=https://test.example.com
NEXT_PUBLIC_DEPLOYMENT_URL=https://api-test.example.com
RUST_LOG=info
DISABLE_BEACON=true
DISABLE_METRICS_ENDPOINT=true
DOCUMENT_RETENTION_DELAY=172800
NEXT_PUBLIC_LOAD_MONACO_INTERNALLY=true

# Web runtime / Clerk / team secret
NEXT_PUBLIC_CONVEX_URL=https://api-test.example.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_FRONTEND_API_URL=https://your-test-issuer.clerk.accounts.dev
CLERK_JWT_ISSUER_DOMAIN=https://your-test-issuer.clerk.accounts.dev
SSHTHING_BROWSER_BASE_URL=https://test.example.com
SSHTHING_TEAM_SECRET_KEY=replace-with-generated-team-secret
